# ============================================================
# Plantilla de variables de entorno para Tennis Trading Bot
# ============================================================
# Copia este archivo a ".env" (sin el ".example") y rellena tus
# valores reales. El archivo ".env" real NUNCA debe subirse a git
# (ya está excluido en .gitignore) porque contiene credenciales.
#
#   cp .env.example .env
#
# Todas estas variables tienen un valor por defecto "de relleno" en
# config.py, así que el bot arrancará igualmente sin .env (usando el
# MockBetsAPIProvider), pero Telegram, RapidAPI y MongoDB no
# funcionarán de verdad hasta que rellenes esto.
# ============================================================

# --- Telegram ---
# Crea un bot con @BotFather en Telegram para obtener el TOKEN.
# El CHAT_ID puede ser el de un chat privado, grupo (empieza por "-")
# o canal; usa @userinfobot o la API getUpdates para encontrarlo.
TELEGRAM_BOT_TOKEN=8805223152:AAET6HNZQx0pQelvu-FUfw9jdUgD8Zq2sWA
TELEGRAM_CHAT_ID=8805223152

# --- RapidAPI (proveedor de datos en vivo) ---
# Producto confirmado: "Tennis API - ATP WTA ITF". Solo necesitas
# rellenar tu RAPIDAPI_KEY; el resto ya apunta al producto correcto
# por defecto en config.py, pero puedes sobreescribirlo aquí si algún
# día cambias de producto.
RAPIDAPI_KEY=6ceeba3ac8mshb3ad2854d7761b5p16174fjsn9d23b9b46b7b
RAPIDAPI_HOST=tennis-api-atp-wta-itf.p.rapidapi.com
RAPIDAPI_BASE_URL=https://tennis-api-atp-wta-itf.p.rapidapi.com
RAPIDAPI_LIVE_ENDPOINT=/tennis/v2/extend/api/events/live
# Si pones esto en "false", el bot no consultará cuotas (ahorra
# créditos) pero entonces NINGÚN partido pasará el motor de reglas,
# ya que la cuota pre-partido es obligatoria.
RAPIDAPI_FETCH_ODDS=true

# --- Flashscore scraping (OPCIONAL, NO recomendado, desactivado por defecto) ---
# Déjalo en "false" salvo que hayas leído flashscore_scraper.py y
# asumas conscientemente el riesgo (incumple TOS de Flashscore).
FLASHSCORE_SCRAPING_ENABLED=false

# --- MongoDB ---
# Si usas Docker local:  docker run -d -p 27017:27017 mongo:7
# Si usas MongoDB Atlas (cluster gratuito), copia el connection
# string que te da el panel de Atlas, con usuario/contraseña incluidos.
MONGO_URI=mongodb+srv://falberola2003_db_user:OIXE1P9wt5PATgXn@bettenistrading.a9rntbs.mongodb.net/?appName=betTenisTrading
MONGO_DB_NAME=betTenisTrading
MONGO_ALERTS_COLLECTION=trading_alerts
# Colecciones usadas por el OpeningOddsTracker (ver opening_odds_tracker.py)
# para resolver la cuota de apertura real de cada partido, cruzando
# fixtures programados con partidos nuevos detectados en vivo.
MONGO_FIXTURES_COLLECTION=fixtures
MONGO_OPENING_ODDS_COLLECTION=opening_odds
# Caché de categoría/superficie real por torneo (resuelta vía rankId
# oficial), para no repetir la consulta a tournament/info en cada ciclo.
MONGO_TOURNAMENT_INFO_COLLECTION=tournament_info

# --- Fixtures: refresco periódico y bajo demanda ---
# Cada cuántos segundos se vuelve a consultar /fixtures/{fecha} para
# refrescar la lista de partidos programados (refresco periódico,
# ambos tours atp+wta).
FIXTURES_REFRESH_INTERVAL_SECONDS=1800
# Cuando un partido nuevo no cruza con ningún fixture ya guardado
# (probablemente empezó después del último refresco periódico), se
# dispara un refresco DIRIGIDO inmediato de su tour_type en vez de
# esperar al próximo ciclo programado. Si tras ese refresco dirigido
# sigue sin encontrarse, este cooldown evita reintentarlo en cada
# ciclo de polling (15s) — solo se reintenta tras este intervalo.
ORPHAN_LOOKUP_COOLDOWN_SECONDS=120
